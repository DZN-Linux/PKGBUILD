# Maintainer: Seth Dawson <dznlinux@gmail.com>

pkgname=dznlinux-fonts-git
_pkgname=dznlinux-fonts
pkgver=r1
pkgrel=1
pkgdesc="Fonts used for DZN Linux"
arch=('any')
url="https://github.com/DZN-Linux/dznlinux-fonts"
license=('GPL-3.0-only')
makedepends=('git')
depends=()
provides=("${_pkgname}")
conflicts=("${_pkgname}")
options=(!strip !emptydirs)
source=("${_pkgname}::git+https://github.com/DZN-Linux/${_pkgname}.git")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_pkgname}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  cd "${srcdir}/${_pkgname}"

  install -dm755 "${pkgdir}/usr/share/fonts/TTF"
  install -m644 usr/share/fonts/TTF/* "${pkgdir}/usr/share/fonts/TTF/"

  install -dm755 "${pkgdir}/usr/share/fonts/OTF"
  install -m644 usr/share/fonts/OTF/* "${pkgdir}/usr/share/fonts/OTF/"

  install -dm755 "${pkgdir}/usr/share/dznlinux/licenses/${_pkgname}"
  install -m644 LICENSE "${pkgdir}/usr/share/dznlinux/licenses/${_pkgname}/"
  install -m644 usr/share/dznlinux/licenses/dznlinux-fonts/* \
    "${pkgdir}/usr/share/dznlinux/licenses/${_pkgname}/"

  install -Dm644 README.md "${pkgdir}/usr/share/doc/${_pkgname}/README.md"
}
