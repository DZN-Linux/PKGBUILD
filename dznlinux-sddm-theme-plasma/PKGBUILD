# Maintainer: Seth Dawson <dznlinux@gmail.com>
pkgname=dznlinux-sddm-theme-plasma-git
_pkgname=dznlinux-sddm-theme-plasma
_destname1="/usr"
_destname2="/etc/sddm.conf.d/"
_licensedir="/usr/share/dznlinux/licenses/"
pkgver=r1.0
pkgrel=1
pkgdesc="DZNLinux SDDM theme for KDE Plasma"
arch=('any')
url="https://github.com/DZN-Linux/${_pkgname}"
license=('GPL-3.0-or-later')
depends=('sddm' 'libplasma' 'qt6-5compat' 'kf6-kirigami' 'plasma-workspace')
optdepends=('qt6-virtualkeyboard: virtual keyboard support at login screen')
makedepends=('git')
provides=('dznlinux-sddm-theme-plasma')
conflicts=('dznlinux-sddm-theme-plasma')
options=(!strip !emptydirs)
source=("${_pkgname}::git+https://github.com/DZN-Linux/dznlinux-sddm-theme-plasma")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_pkgname}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
	install -dm755 ${pkgdir}${_licensedir}${_pkgname}
	install -m644  ${srcdir}/${_pkgname}/LICENSE ${pkgdir}${_licensedir}${_pkgname}

	cp -r ${srcdir}/${_pkgname}/${_destname1} ${pkgdir}

	install -dm755 ${pkgdir}${_destname2}
	cp -r  ${srcdir}/${_pkgname}${_destname2}* ${pkgdir}${_destname2}
}
